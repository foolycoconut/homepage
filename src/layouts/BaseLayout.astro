---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Shengming Zhou",
  description = "Personal homepage for Shengming Zhou.",
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const navItems = [
  { href: "/", label: "Home" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
  { href: "/cv", label: "CV" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <a class="text-sm font-semibold tracking-[0.2em] text-ink" href="/">SHENGMING ZHOU</a>
        <nav class="site-nav" aria-label="Primary">
          {
            navItems.map((item) => (
              <a href={item.href} data-active={pathname === item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main class="space-y-20">
        <slot />
      </main>
      <footer class="footer-note">
        <p>Built with Astro and deployed on GitHub Pages.</p>
      </footer>
    </div>
  </body>
</html>
