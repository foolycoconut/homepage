---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog | Shengming Zhou" description="Blog and notes by Shengming Zhou.">
  <section class="page-intro">
    <p class="eyebrow">Blog</p>
    <h1 class="page-title">Notes and writing</h1>
    <div class="page-body space-y-6">
      <p>
        This page is reserved for short writing, reading notes, and occasional updates.
        I am keeping it minimal for now rather than filling it with placeholder posts.
      </p>
      <p>
        Once I start publishing more regularly, this page can expand into a proper
        archive.
      </p>
    </div>
  </section>

  <section class="card max-w-3xl">
    <p class="eyebrow">Status</p>
    <h2 class="card-title mt-4">No posts yet</h2>
    <p class="mt-4 text-sm leading-7 text-ink/74">
      The structure is here so the site can grow without changing its overall design.
    </p>
  </section>
</BaseLayout>
