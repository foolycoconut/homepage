---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Shengming Zhou" description="Contact information for Shengming Zhou.">
  <section class="page-intro">
    <p class="eyebrow">Contact</p>
    <h1 class="page-title">Get in touch</h1>
    <div class="page-body space-y-6">
      <p>
        The simplest way to reach me is by email. You can also find my public code on
        GitHub.
      </p>
    </div>
  </section>

  <section class="simple-grid">
    <article class="card">
      <p class="eyebrow">Email</p>
      <h2 class="card-title mt-4">
        <a class="muted-link" href="mailto:zhou2412@umn.edu">zhou2412@umn.edu</a>
      </h2>
      <p class="mt-4 text-sm leading-7 text-ink/74">
        Best for academic, project, or general contact.
      </p>
    </article>

    <article class="card">
      <p class="eyebrow">GitHub</p>
      <h2 class="card-title mt-4">
        <a class="muted-link" href="https://github.com/foolycoconut">github.com/foolycoconut</a>
      </h2>
      <p class="mt-4 text-sm leading-7 text-ink/74">
        Public repositories and ongoing code work.
      </p>
    </article>
  </section>
</BaseLayout>
