---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Shengming Zhou" description="Personal homepage for Shengming Zhou.">
  <section class="hero-grid">
    <div class="page-intro">
      <p class="eyebrow">Computer Science Student</p>
      <h1 class="page-title">Shengming Zhou</h1>
      <div class="page-body space-y-6">
        <p>
          I am a computer science student at the University of Minnesota. Before
          studying computer science, I also studied mathematics, and I remain
          interested in work that sits between mathematical thinking and computational
          systems.
        </p>
        <p>
          My current interests include databases, machine learning evaluation, and
          research-oriented software. This site is meant to stay simple: a short
          introduction, a small record of experience, occasional updates, and clear
          contact information.
        </p>
      </div>
    </div>
    <div class="hero-photo" aria-label="Optional profile photo placeholder">
      <p>Add Photo Here</p>
    </div>
  </section>

  <section class="section-stack">
    <section class="section-rule">
      <p class="eyebrow">Experience</p>
      <h2 class="section-heading mt-3">Selected experience</h2>
      <div class="entry-list mt-6">
        <article>
          <div class="entry-title-row">
            <div>
              <h3 class="entry-title">Research Assistant</h3>
              <p class="entry-subtitle">Long-horizon LLM Memory and Personalization Benchmark Project</p>
            </div>
            <p class="entry-meta">2026</p>
          </div>
          <p class="entry-copy">
            Built automated data processing and evaluation workflows in Python, managed
            Linux-based experiment environments, and developed validation checks for
            benchmarking data quality and output reliability.
          </p>
        </article>

        <article>
          <div class="entry-title-row">
            <div>
              <h3 class="entry-title">University of Minnesota</h3>
              <p class="entry-subtitle">B.A. in Computer Science</p>
            </div>
            <p class="entry-meta">2025 - Present</p>
          </div>
          <p class="entry-copy">
            Currently studying computer science with coursework in matrix theory,
            database systems, and graphics.
          </p>
        </article>

        <article>
          <div class="entry-title-row">
            <div>
              <h3 class="entry-title">Shandong University</h3>
              <p class="entry-subtitle">B.S. in Mathematics and Applied Mathematics</p>
            </div>
            <p class="entry-meta">2023 - 2025</p>
          </div>
          <p class="entry-copy">
            Completed undergraduate study in mathematics with coursework including
            analysis, probability theory, and ordinary differential equations.
          </p>
        </article>
      </div>
    </section>

    <section class="section-rule">
      <p class="eyebrow">News</p>
      <h2 class="section-heading mt-3">Recent updates</h2>
      <div class="entry-list mt-6">
        <article>
          <div class="entry-title-row">
            <h3 class="entry-title">Homepage launched</h3>
            <p class="entry-meta">April 2026</p>
          </div>
          <p class="entry-copy">
            This site is now online as a simple academic portfolio and will gradually
            expand as I write more and build out future work.
          </p>
        </article>
      </div>
    </section>

    <section class="section-rule">
      <p class="eyebrow">Contact</p>
