---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import SectionHeading from "../components/SectionHeading.astro";
import WritingList from "../components/WritingList.astro";

const projects = (await getCollection("projects"))
  .filter((entry) => entry.data.featured)
  .sort((a, b) => b.data.year.localeCompare(a.data.year));

const writing = (await getCollection("writing")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);
---

<BaseLayout title="Shengming Zhou" description="Personal homepage for Shengming Zhou.">
  <Hero />

  <section id="about" class="section-grid">
    <SectionHeading
      label="About"
      title="Keep the intro direct."
      intro="A homepage works better when it explains your current direction, not your full history."
    />
    <div class="surface space-y-5 p-6 md:p-8">
      <p class="text-lg leading-8 text-ink/78">
        I am Shengming Zhou, a student of UofM. This site is a small home for my
        background, projects, and notes as I keep learning and building.
      </p>
      <p class="section-copy">
        The structure is intentionally simple: a clear introduction, selected work,
        and a place to publish ideas or progress over time.
      </p>
    </div>
  </section>

  <section id="projects" class="section-grid">
    <SectionHeading
      label="Selected Work"
      title="Show a few things with enough context."
      intro="Three strong projects with clear summaries are usually better than ten undifferentiated cards."
    />
    <ProjectGrid items={projects} />
  </section>

  <section id="writing" class="section-grid">
    <SectionHeading
      label="Notes"
      title="Reserve space for writing from day one."
      intro="Even if you only publish occasionally, the site should already have a place for thinking in public."
    />
    <WritingList items={writing} />
  </section>

  <section id="contact" class="section-grid">
    <SectionHeading
      label="Contact"
      title="Link the profiles you actually use."
      intro="Keep this simple so someone can reach you or inspect your work with one click."
    />
    <div class="surface grid gap-5 p-6 md:grid-cols-3 md:p-8">
      <a class="rounded-3xl border border-ink/10 p-5 hover:border-moss hover:bg-moss/5" href="https://github.com/foolycoconut">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-moss">GitHub</p>
        <p class="mt-3 text-lg font-semibold">github.com/foolycoconut</p>
      </a>
      <a class="rounded-3xl border border-ink/10 p-5 hover:border-moss hover:bg-moss/5" href="mailto:you@example.com">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-moss">Email</p>
        <p class="mt-3 text-lg font-semibold">you@example.com</p>
      </a>
      <a class="rounded-3xl border border-ink/10 p-5 hover:border-moss hover:bg-moss/5" href="https://x.com/your-name">
        <p class="font-mono text-xs uppercase tracking-[0.24em] text-moss">Social</p>
        <p class="mt-3 text-lg font-semibold">@your-name</p>
      </a>
    </div>
  </section>
</BaseLayout>
