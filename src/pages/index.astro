      <ul class="contact-list mt-6">
        <li><span class="contact-label">GitHub</span><a class="muted-link" href="https://github.com/foolycoconut">github.com/foolycoconut</a></li>
        <li><span class="contact-label">LinkedIn</span><span>To be added</span></li>
        <li><span class="contact-label">Email</span><a class="muted-link" href="mailto:zhou2412@umn.edu">zhou2412@umn.edu</a></li>
        <li><span class="contact-label">CV</span><a class="muted-link" href="/Shengming-Zhou-CV.pdf">Download PDF</a></li>
