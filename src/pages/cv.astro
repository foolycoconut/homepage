---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CV | Shengming Zhou" description="Curriculum vitae for Shengming Zhou.">
  <section class="page-intro">
    <p class="eyebrow">CV</p>
    <h1 class="page-title">Curriculum Vitae</h1>
    <div class="page-body space-y-6">
      <p>
        The most current version of my CV is available as a PDF.
      </p>
    </div>
  </section>

  <section class="card max-w-3xl">
    <p class="eyebrow">Download</p>
    <h2 class="card-title mt-4">
      <a class="muted-link" href="/Shengming-Zhou-CV.pdf">Shengming-Zhou-CV.pdf</a>
    </h2>
    <p class="mt-4 text-sm leading-7 text-ink/74">
      Open the PDF in the browser or download it directly from this page.
    </p>
  </section>
</BaseLayout>
