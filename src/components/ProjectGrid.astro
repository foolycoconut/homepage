---
import type { CollectionEntry } from "astro:content";

interface Props {
  items: CollectionEntry<"projects">[];
}

const { items } = Astro.props;
---

<div class="grid gap-5 lg:grid-cols-2">
  {
    items.map((project) => (
      <article class="surface flex h-full flex-col gap-5 p-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.24em] text-moss">{project.data.year}</p>
            <h3 class="mt-3 text-xl font-semibold">{project.data.title}</h3>
          </div>
          <span class="rounded-full bg-sand px-3 py-1 font-mono text-xs text-ink/70">
            featured
          </span>
        </div>
        <p class="section-copy flex-1">{project.data.summary}</p>
        <div class="flex flex-wrap gap-2">
          {project.data.stack.map((item) => (
            <span class="rounded-full border border-ink/10 px-3 py-1 text-sm text-ink/75">
              {item}
            </span>
          ))}
        </div>
        {
          project.data.href && (
            <a class="text-sm font-medium text-clay hover:text-moss" href={project.data.href}>
              Open project
            </a>
          )
        }
      </article>
    ))
  }
</div>
