---
interface Props {
  label: string;
  title: string;
  intro: string;
}

const { label, title, intro } = Astro.props;
---

<div class="space-y-3">
  <p class="eyebrow">{label}</p>
  <h2 class="text-2xl font-semibold tracking-tight md:text-3xl">{title}</h2>
  <p class="section-copy max-w-xs">{intro}</p>
</div>
