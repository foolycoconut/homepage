---
import type { CollectionEntry } from "astro:content";

interface Props {
  items: CollectionEntry<"writing">[];
}

const { items } = Astro.props;
---

<div class="space-y-4">
  {
    items.map((entry) => (
      <article class="surface flex flex-col gap-4 p-6 md:flex-row md:items-start md:justify-between">
        <div class="space-y-2">
          <p class="font-mono text-xs uppercase tracking-[0.24em] text-moss">{entry.data.date}</p>
          <h3 class="text-xl font-semibold">{entry.data.title}</h3>
          <p class="section-copy max-w-2xl">{entry.data.summary}</p>
        </div>
        {entry.data.href ? (
          <a class="pt-1 text-sm font-medium text-clay hover:text-moss" href={entry.data.href}>
            Read
          </a>
        ) : (
          <span class="pt-1 text-sm text-ink/45">Draft</span>
        )}
      </article>
    ))
  }
</div>
